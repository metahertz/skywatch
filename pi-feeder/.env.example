# pi-feeder configuration.
#
# This file is auto-generated and overwritten by the manager UI on
# every "Apply".  Editing it by hand is fine — the manager re-reads
# it on the next form load — but the next save from the UI will
# replace your edits.
#
# Required for ANY feeder to do anything useful:
FEEDER_LAT=51.4775
FEEDER_LON=-0.4614
FEEDER_ALT_M=80
FEEDER_TZ=Europe/London

# Comma-separated list of enabled compose profiles.  The manager
# rewrites this; valid values:
#   ultrafeeder, skywatch, skywatch-edge, vdl2,
#   piaware, fr24, adsbexchange, planefinder, radarbox,
#   opensky, airframes-1090, airframes-vdl2
# `ultrafeeder` is always active (it's the SDR core); listing it is
# harmless.  `skywatch` (monolithic, serves the UI from this host)
# and `skywatch-edge` (sender to a remote central) are mutually
# exclusive — enable one or the other, not both.
COMPOSE_PROFILES=ultrafeeder

# ─── Per-feeder sharing keys ───────────────────────────────────────
# Leave blank when the feeder is disabled.  The manager UI is the
# normal way to set these — direct edits work but get overwritten.

# FlightAware (https://flightaware.com/adsb/piaware/claim)
PIAWARE_FEEDER_ID=

# FlightRadar24 (run `docker run --rm -it ghcr.io/sdr-enthusiasts/docker-fr24feed
# /scripts/signup.sh` once interactively to obtain)
FR24_KEY=

# ADSBExchange (uuid generated on first run; persist to keep the
# same identity)
ADSBX_UUID=

# PlaneFinder (https://planefinder.net/sharing/client/registration)
PLANEFINDER_SHARECODE=

# RadarBox (https://www.radarbox.com/raspberry-pi)
RBFEEDER_KEY=

# OpenSky Network (https://opensky-network.org/data/share-data)
OPENSKY_USER=
OPENSKY_SERIAL=

# airframes.io (https://app.airframes.io/feeder)
AIRFRAMES_STATION_ID=
AIRFRAMES_FEEDER_KEY=

# ─── Skywatch edge mode (sender → remote central) ──────────────────
# Only used when the `skywatch-edge` profile is enabled.  All three
# values are mandatory in that mode; leave blank otherwise.
#
# Stable name reported as receiver_id at the central; pick something
# distinct per site (hostname is a fine default).
SKYWATCH_EDGE_NAME=
# WebSocket URL of the central node's ingest endpoint.
SKYWATCH_CENTRAL_URL=
# Bearer token the central will accept on the ingest socket.
SKYWATCH_INGEST_TOKEN=

# ─── SDR device identifiers ────────────────────────────────────────
# Two-dongle setups: name your dongles via `rtl_eeprom -d N -s NAME`.
# Default scheme: rtlsdr-1090 for the 1090 MHz dongle, rtlsdr-vdl2
# for the 136 MHz dongle.  Containers reference dongles by name so a
# dongle reorder on the USB bus doesn't swap their roles.
SDR_1090_SERIAL=rtlsdr-1090
SDR_VDL2_SERIAL=rtlsdr-vdl2

# 1090 MHz dongle gain (0..49.6, or "agc").  Tune by watching
# graphs1090 — too high → CPU saturated by noise, too low → range
# loss.  Default 40 works for most antennas.
SDR_1090_GAIN=40

# VDL2 dongle gain — same scale, slightly higher typical value
# because VDL2 signals are weaker.
SDR_VDL2_GAIN=44

# Centre frequency for VDL2 (Hz).  Default 136.85 MHz covers all
# five operational European channels in a 1.05 MS/s window.
VDL2_CENTERFREQ=136850000
